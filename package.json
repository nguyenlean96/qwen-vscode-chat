{
  "name": "qwen-vscode-chat",
  "publisher": "nguyenlean96",
  "displayName": "Qwen VSCode Chat",
  "description": "A VS Code chat extension for Qwen and other models hosted on Alibaba platform.",
  "repository": {
    "type": "git",
    "url": "https://github.com/nguyenlean96/qwen-vscode-chat"
  },
  "version": "0.1.0",
  "engines": {
    "vscode": "^1.109.0"
  },
  "categories": [
    "AI",
    "Chat"
  ],
  "activationEvents": [],
  "galleryBanner": {},
  "badges": [],
  "homepage": "",
  "bugs": {
    "url": "https://github.com/nguyenlean96/qwen-vscode-chat/issues"
  },
  "main": "./dist/extension.js",
  "contributes": {
    "languageModelChatProviders": [
      {
        "vendor": "qwen",
        "displayName": "Qwen",
        "managementCommand": "qwen.manage"
      }
    ],
    "commands": [
      {
        "command": "qwen.manage",
        "title": "Manage Qwen Provider"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "pnpm run package",
    "compile": "pnpm run check-types && pnpm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "pnpm run check-types && pnpm run lint && node esbuild.js --production",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "pnpm run compile-tests && pnpm run compile && pnpm run lint",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@stylistic/eslint-plugin": "^5.9.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "^22",
    "@types/vscode": "^1.103.0",
    "@vscode/dts": "^0.4.1",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "esbuild": "^0.27.2",
    "eslint": "^9.39.2",
    "jsonrepair": "^3.13.2",
    "npm-run-all": "^4.1.5",
    "openai": "^6.25.0",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.54.0"
  }
}
